# Copy this file to .env.local and fill in your Supabase project credentials.
# Without these, SyncQuest still boots and lets you preview the UI, but realtime
# availability sync and quest persistence are disabled.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Optional. Public origin used to build absolute URLs for OpenGraph and
# Twitter card previews (e.g. https://syncquest.app). Falls back to
# http://localhost:3000 when unset, which is fine for local dev.
NEXT_PUBLIC_SITE_URL=
